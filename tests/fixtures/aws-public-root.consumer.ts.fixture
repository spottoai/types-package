    },
    instructionsMarkdown: '# Spotto AWS onboarding instructions',
  },
};

const acceptedResponse: AwsCloudAccountSetupAcceptedResponse = {
  provider: 'AWS',
  cloudAccountId: 'cloud-account-123',
  accountId: '123456789012',
  requestId: 'request-123',
  correlationId: 'correlation-123',
  status: 'pending',
  acceptedAt: '2026-07-15T00:00:00.000Z',
};

const onboardRequest: AwsOnboardRequestMessageV1 = {
  schemaVersion: AWS_REQUEST_SCHEMA_VERSION,
  provider: AWS_REQUEST_PROVIDER,
  entity: 'cloudaccount',
  action: 'onboard',
  companyId: 'company-123',
  cloudAccountId: 'cloud-account-123',
  awsAccountId: '123456789012',
  roleArn: setupRequest.roleArn,
  externalId: setupPreparationResponse.externalId,
  requestId: acceptedResponse.requestId,
  correlationId: acceptedResponse.correlationId,
  requestedAt: acceptedResponse.acceptedAt,
