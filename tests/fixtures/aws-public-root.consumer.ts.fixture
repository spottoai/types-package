} satisfies ArtifactGenerationManifest<'aws', '123456789012', 'portal-run-1'>;

const publicAccountSummary = {
  schemaVersion: AWS_PUBLIC_ARTIFACT_SCHEMA_VERSION,
  provider: 'aws',
  accountId: '123456789012',
  artifactType: 'account-summary',
  artifactGeneration: generationManifest.artifactGeneration,
  account: {
    provider: 'aws',
    accountId: '123456789012',
    displayName: 'Production AWS',
  },
  timestamp: acceptedResponse.acceptedAt,
} satisfies AwsPortalAccountSummaryArtifact<'123456789012', 'portal-run-1'>;
const packedAwsPublicArtifact: PackedAwsPublicArtifacts = publicAccountSummary;

void [
  setupRequest,
  setupPreparationRequest,
  setupPreparationResponse,
  requestActions,
  forbiddenCredentialFields,
  acceptedResponse,
  onboardRequest,
  publicAwsAccount,
  publicAwsAccountWithExternalId,
  publicAwsAccountWithResolvedCredentials,
  dailyMetrics,
  dailyCostPeriod,
  resourceSpend,
  report,
  generationManifest,
  publicAccountSummary,
  publicArtifactTypes,
  packedAwsPublicArtifact,
];
