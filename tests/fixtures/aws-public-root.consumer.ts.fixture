} from '@spottoai/types-package/aws';

const requestActions: readonly AwsRequestActionV1[] = AWS_REQUEST_ACTIONS;
const forbiddenCredentialFields: readonly AwsRequestForbiddenCredentialField[] = AWS_REQUEST_FORBIDDEN_CREDENTIAL_FIELDS;
const publicArtifactTypes = AWS_PUBLIC_ARTIFACT_TYPES;
type PackedAwsPublicArtifacts =
  | AwsPortalAccountSummaryArtifact
  | AwsPortalResourceCollectionArtifact
  | AwsPortalRelationshipArtifact
  | AwsPortalLifecycleArtifact
  | AwsPluginSubscriptionArtifact
  | AwsPluginResourceArtifact;

const setupRequest: AwsCloudAccountSetupRequest = {
  provider: 'AWS',
  companyId: 'company-123',
  name: 'Production AWS',
  authMode: 'crossAccountRole',
  roleArn: 'arn:aws:iam::123456789012:role/SpottoReadOnly',
};

const setupPreparationRequest: AwsCloudAccountSetupPreparationRequest = {};

const setupPreparationResponse: AwsCloudAccountSetupPreparationResponse = {
  provider: 'AWS',
  externalId: 'spotto-generated-external-id',
  createdAt: '2026-07-15T00:00:00.000Z',
  onboardingBundle: {
    schemaVersion: 1,
