  totalSpend: 1,
  currency: 'NZD',
  currencySymbol: '$',
};

const generationManifest = {
  schemaVersion: ARTIFACT_GENERATION_SCHEMA_VERSION,
  provider: 'aws',
  accountId: '123456789012',
  artifactGeneration: {
    runId: 'portal-run-1',
    generatedAt: acceptedResponse.acceptedAt,
  },
  status: 'completed',
  artifacts: [
    {
      name: 'account-summary',
      mediaType: 'application/json',
      contentEncoding: 'gzip',
      byteLength: 100,
      sha256: 'a'.repeat(64),
    },
  ],
  sourceGenerations: [
    {
      provider: 'aws',
      accountId: '123456789012',
      source: 'ec2-instances',
      status: 'available',
      generationId: 'ec2-generation-1',
      generatedAt: acceptedResponse.acceptedAt,
