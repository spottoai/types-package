const publicAwsAccount: PublicCloudAccountDto = {
  companyId: 'company-123',
  id: 'cloud-account-123',
  name: 'Production AWS',
  companyName: 'Spotto',
  provider: 'AWS',
  authMode: 'crossAccountRole',
  accountId: '123456789012',
  roleArn: setupRequest.roleArn,
  status: 'pending',
  createdAt: new Date(acceptedResponse.acceptedAt),
  updatedAt: new Date(acceptedResponse.acceptedAt),
  createdBy: 'user-123',
};

const publicAwsAccountWithExternalId: PublicCloudAccountDto = {
  ...publicAwsAccount,
  // @ts-expect-error Setup-only external IDs must remain excluded from the packed public DTO.
  externalId: 'customer-secret-external-id',
};

const publicAwsAccountWithResolvedCredentials: PublicCloudAccountDto = {
  ...publicAwsAccount,
  // @ts-expect-error Resolved AWS credentials must remain excluded from the packed public DTO.
  credentials: { accessKeyId: 'AKIAEXAMPLE', secretAccessKey: 'raw-secret' },
};

const dateBasis: CostDateBasis = 'company-local';
const dailyMetrics: DailyMetrics = {
  date: 20260715,
  basis: dateBasis,
  timeZone: 'Pacific/Auckland',
  spend: 1,
  costAmortized: 1,
  summary: [],
};
const dailyCostPeriod: ResourceCostPeriodMetadata = {
  kind: 'daily',
  name: 'daily_2026-07-15',
  label: 'Jul 15, 2026',
  date: '2026-07-15',
  startDate: 20260715,
  endDate: 20260715,
  basis: 'billing-calendar',
};
const resourceSpend = {
  cost: 1,
  quantity: 1,
  date: 20260715,
  dateBasis,
  dateTimeZone: 'Pacific/Auckland',
  meterCategory: 'Compute',
  meterSubCategory: 'Virtual Machines',
